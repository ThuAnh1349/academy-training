# Frontend Environment Variables (Vite)

# Cấu hình API Backend riêng của dự án Academy (Không dùng chung nquoc.vn)
VITE_API_BASE_URL=https://api.your-academy-domain.com

# Cấu hình Supabase riêng (Dự án mới hoàn toàn)
VITE_SUPABASE_URL=https://your-new-supabase-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_new_supabase_anon_key

# Cấu hình PostgreSQL Database (Dành cho Backend/Vercel Serverless Functions)
# Chuỗi kết nối trực tiếp đến PostgreSQL (Ví dụ lấy từ Supabase Database Settings)
DATABASE_URL="postgresql://postgres.[your-project-ref]:[your-password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[your-project-ref]:[your-password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Các biến Optional (Theo chuẩn kiến trúc Phase 3)
VITE_OPTIONAL_ACADEMY_GOV_API_KEY=
